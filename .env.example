# Pick one provider. 'gemini' is free with no credit card; 'anthropic' requires $5 prepaid.
LLM_PROVIDER=gemini

# Anthropic — required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Gemini — required if LLM_PROVIDER=gemini. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

TAVILY_API_KEY=tvly-...

# Optional model overrides (defaults are sensible per provider):
# anthropic: claude-haiku-4-5-20251001 / claude-sonnet-4-6
# gemini:    gemini-2.5-flash / gemini-2.5-flash
EXTRACT_MODEL=
SYNTHESIZE_MODEL=

OUTPUT_DIR=./prep

# RAG layer
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CHROMA_DIR=./.chroma
PLAYBOOK_COLLECTION=playbook

# Observability
TRACE_DB_PATH=./traces.sqlite

# Calendar (Phase 6) — see README for Google Cloud setup
# GOOGLE_CLIENT_SECRET_PATH=~/.config/prep-agent/google_client_secret.json
# GOOGLE_TOKEN_PATH=~/.config/prep-agent/google_token.json
# GOOGLE_CALENDAR_ID=primary

# Deploy (Phase 7) — leave empty for local dev, set for hosted instances
# STREAMLIT_AUTH_PASSWORD=change-me
